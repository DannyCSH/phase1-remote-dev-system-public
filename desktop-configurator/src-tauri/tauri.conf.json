{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Phase1 Desktop Configurator",
  "version": "0.1.0",
  "identifier": "com.phase1.desktopconfigurator",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Phase1 Desktop Configurator",
        "width": 1360,
        "height": 900,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
